COCO_FEISHU_APP_ID=your_app_id
COCO_FEISHU_APP_SECRET=your_app_secret

# Or configure multiple bots and start all of them with `npm run feishu`
# COCO_FEISHU_APP_ID_1=your_app_id_1
# COCO_FEISHU_APP_SECRET_1=your_app_secret_1
# COCO_FEISHU_APP_ID_2=your_app_id_2
# COCO_FEISHU_APP_SECRET_2=your_app_secret_2

# Optional
# COCO_FEISHU_PROXY=http://127.0.0.1:7890
# COCO_FEISHU_USERS=ou_xxx,ou_yyy
# COCO_FEISHU_CHATS=oc_xxx,oc_yyy
# COCO_CODEX_RESUME_MAX_ATTEMPTS=5
# COCO_CODEX_RESUME_RETRY_DELAY_MS=3000
